# Copy to .env for local overrides, or set these as Railway service variables.

# Generate one: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Keep False in production.
DEBUG=False

# Comma-separated. Railway also auto-adds RAILWAY_PUBLIC_DOMAIN for you.
ALLOWED_HOSTS=your-app.up.railway.app

# Comma-separated, full origin including scheme, no trailing slash.
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend.vercel.app

# Provided automatically by Railway's Postgres plugin. Falls back to local sqlite if unset.
DATABASE_URL=
